#include <stdio.h>

int main() {
int n, i, flag = 1;
printf("Enter a number: ");
scanf("%d", &n);
for(i = 2; i <= n/2; i++) {
        if(n % i == 0) {
            flag = 0;
            break;
}}
if(n <= 1)
 printf("Not Prime");
else if(flag == 1)
 printf("Prime");
else
printf("Not Prime");

    return 0;
}
