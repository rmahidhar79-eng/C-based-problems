#include <stdio.h>
int main() {
int planType;
int paymentMode;
int plancost = 0;
int cashback = 0;
scanf("%d %d",&planType,&paymentMode);

 
    switch(planType){
        case 1:
        plancost = 199;
        break;
        case 2:
        plancost = 399;
        break;
        default:
        printf("Invalid plan");
        return 0;
    }
    switch(paymentMode){
        case 11:
        case 12:
        cashback = 20;
        break;
        case 13:
        cashback = 0;
        break;
        default:
        printf("Invalid payment mode");
        return 0;
    }
    printf("final cost = %d",plancost-cashback);

    return 0;
}
