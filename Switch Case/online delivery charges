#include <stdio.h>
int main() {
int orderAmount;
int speedType;
int delivery = 0;
scanf("%d %d",&orderAmount,&speedType);

    switch(speedType){
        case 1:
        delivery = 50;
        break;
        case 2:
        if(orderAmount<1000){
            delivery = 100;
        }
        else if(orderAmount>=1000){
            delivery = 0;
        }
        break;
        default:
        printf("Invalid Amount");
        return 0;

    }
        printf("delivery Amount = %d",delivery);
        return 0;
}
