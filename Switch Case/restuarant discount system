#include <stdio.h>
int main() {
int customertype,billamount;
float discount = 0;
scanf("%d %d",&customertype,&billamount);

        switch(customertype){
            case 1:
            discount = billamount*0.05;
            break;
            case 2:
            discount = billamount*0.15;
            break;
            default:
            printf("Invalid");
            return 0;


        }
        int finalbillamount = billamount-discount;
        printf("%d",finalbillamount);
    
       return 0;
}
