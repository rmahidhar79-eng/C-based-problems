#include <stdio.h>
int main() {
    int flightclass,wt;
    int charges = 0;
    scanf("%d %d",&flightclass,&wt);

        switch(flightclass){
            case 1:
            charges = 300*wt;
            break;
            case 2:
            if(charges<=3){
                charges = 0;
            }
                else{
                    charges = (wt -3)*300;
                }
            
            break;
            default:
            printf("Invalid");
            return 0;
        }
        printf("%d",charges);
        return 0;
}
