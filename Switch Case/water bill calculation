#include <stdio.h>
int main() {
int connectiontype,units;
int bill = 0;
scanf("%d %d",&connectiontype,&units);

        switch(connectiontype){
            case 1:
            if(units<=30){
                bill = 5*units;
            }
                else {
                    bill = (30*5)+((units-30)*8);
                }
                break;
                case 2:
                bill = units*10;
                break;
            default:
             printf("Invalid");
             return 0;
            
        }
        printf("%d",bill);
        return 0;
}
